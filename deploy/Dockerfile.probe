FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd ./cmd
COPY internal ./internal
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/probe-server ./cmd/probe-server

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/probe-server /probe-server
EXPOSE 8443/tcp 53/tcp 53/udp
ENTRYPOINT ["/probe-server"]

